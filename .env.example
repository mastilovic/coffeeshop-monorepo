# Copy to coffeeshop/.env (used by docker compose include) or export in your shell.

# App database
POSTGRES_DB=coffeeshop
POSTGRES_USER=coffeeshop
POSTGRES_PASSWORD=coffeeshop_dev_password
POSTGRES_PORT=25432

# Keycloak database
KEYCLOAK_POSTGRES_DB=keycloak
KEYCLOAK_POSTGRES_USER=keycloak
KEYCLOAK_POSTGRES_PASSWORD=keycloak_dev_password
KEYCLOAK_POSTGRES_PORT=25433

# Keycloak admin
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Backend / Keycloak clients
KEYCLOAK_REALM=coffeeshop
KEYCLOAK_BACKEND_CLIENT_ID=coffeeshop-backend
KEYCLOAK_BACKEND_CLIENT_SECRET=local-backend-secret

# Host ports
BACKEND_PORT=18080
FRONTEND_PORT=4200
CORS_ALLOWED_ORIGINS=http://localhost:4200
