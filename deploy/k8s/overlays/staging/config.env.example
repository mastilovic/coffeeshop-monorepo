# Copy to config.env and set your staging hostnames (must match DNS and realm-coffeeshop.json).
APP_HOST=staging.app.example.com
AUTH_HOST=staging.auth.example.com

POSTGRES_DB=coffeeshop
POSTGRES_USER=coffeeshop
KEYCLOAK_POSTGRES_DB=keycloak
KEYCLOAK_POSTGRES_USER=keycloak

KC_DB_URL=jdbc:postgresql://postgres-keycloak:5432/keycloak
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/coffeeshop

KEYCLOAK_REALM=coffeeshop
KEYCLOAK_BACKEND_CLIENT_ID=coffeeshop-backend
KEYCLOAK_JWT_ISSUER_URI=https://staging.auth.example.com/realms/coffeeshop
CORS_ALLOWED_ORIGINS=https://staging.app.example.com
