# CI/CD: generated by deploy workflow from GitHub Variables STAGING_APP_HOST / STAGING_AUTH_HOST.
# Local: copy to config.env, set values, then run ./render-local.sh before kubectl apply.

APP_HOST=staging.app.coffeeshop.com
AUTH_HOST=staging.auth.coffeeshop.com

POSTGRES_DB=coffeeshop
POSTGRES_USER=coffeeshop
KEYCLOAK_POSTGRES_DB=keycloak
KEYCLOAK_POSTGRES_USER=keycloak

KC_DB_URL=jdbc:postgresql://postgres-keycloak:5432/keycloak
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/coffeeshop

KEYCLOAK_REALM=coffeeshop
KEYCLOAK_BACKEND_CLIENT_ID=coffeeshop-backend
KEYCLOAK_JWT_ISSUER_URI=https://staging.auth.coffeeshop.com/realms/coffeeshop
CORS_ALLOWED_ORIGINS=https://staging.app.coffeeshop.com
