# App database
POSTGRES_DB=coffeeshop
POSTGRES_USER=coffeeshop
POSTGRES_PASSWORD=coffeeshop_dev_password
POSTGRES_PORT=25432

# Keycloak database (Docker)
KEYCLOAK_POSTGRES_DB=keycloak
KEYCLOAK_POSTGRES_USER=keycloak
KEYCLOAK_POSTGRES_PASSWORD=keycloak_dev_password
KEYCLOAK_POSTGRES_PORT=25433

# Keycloak container admin (master realm)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Backend ↔ Keycloak (align with docker/keycloak/realm-coffeeshop.json client)
KEYCLOAK_REALM=coffeeshop
KEYCLOAK_BASE_URL=http://keycloak:8080
KEYCLOAK_JWT_ISSUER_URI=http://keycloak:8080/realms/coffeeshop
KEYCLOAK_BACKEND_CLIENT_ID=coffeeshop-backend
KEYCLOAK_BACKEND_CLIENT_SECRET=local-backend-secret

# Optional aliases (see application.yaml)
# KEYCLOAK_SERVER_URL=http://localhost:8080
# KEYCLOAK_CLIENT_ID=coffeeshop-backend
# KEYCLOAK_CLIENT_SECRET=local-backend-secret
# KEYCLOAK_ADMIN_USER=admin

BACKEND_PORT=18080
FRONTEND_PORT=4200
CORS_ALLOWED_ORIGINS=http://localhost:4200
